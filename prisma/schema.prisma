generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum PricingTier {
  GRATIS
  BASIS
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  OWNER
  EDITOR
  VIEWER
}

enum SubscriptionTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  naam          String?
  password      String?
  image         String?
  role          UserRole  @default(OWNER)

  // Trial: 14-day Professional trial for new users
  trialEndsAt   DateTime?

  // Relations
  accounts     Account[]
  sessions     Session[]
  reports      RieReport[]
  branding     BrandingConfig?
  subscription Subscription?
  apiKeys      ApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id])
  tier                 SubscriptionTier   @default(STARTER)
  status               SubscriptionStatus @default(ACTIVE)
  billingCycle         BillingCycle       @default(MONTHLY)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model BrandingConfig {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String   @unique
  logoUrl      String?
  primaryColor String?
  companyName  String?
  websiteUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RieReport {
  id              String       @id @default(cuid())
  user            User         @relation(fields: [userId], references: [id])
  userId          String

  // Company info
  bedrijfsnaam    String
  branche         String
  aantalMedewerkers Int
  aantalLocaties  Int          @default(1)

  // Intake
  intakeData      Json

  // AI output
  generatedContent Json?
  samenvatting    String?

  // Status
  status          ReportStatus @default(PENDING)
  tier            PricingTier  @default(GRATIS)

  // PDF
  pdfGenerated    Boolean      @default(false)

  // AI metadata
  tokensUsed      Int?
  generationTimeMs Int?

  // Signatures (digital signing)
  signatures      Json?        // Array of {role, name, functie, signatureImage, signedAt}

  // Verification watermark
  verificationCode String?      @unique

  // Plan van Aanpak status per item
  pvaStatuses     Json?        // Array of {index, status: "niet_gestart"|"in_behandeling"|"afgerond"}

  // Payment
  payments        Payment[]
  signLinks       SignLink[]
  complianceChecks ComplianceCheck[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
}

model SignLink {
  id        String   @id @default(cuid())
  token     String   @unique
  reportId  String
  report    RieReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  role      String   // werkgever, preventiemedewerker, arbodeskundige
  email     String?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([reportId])
}

model Payment {
  id                  String        @id @default(cuid())
  stripeSessionId     String        @unique
  stripePaymentIntent String?
  amount              Int
  currency            String        @default("eur")
  status              PaymentStatus @default(PENDING)
  tier                PricingTier
  email               String

  report              RieReport?    @relation(fields: [reportId], references: [id])
  reportId            String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([stripeSessionId])
  @@index([reportId])
}

model EmailEvent {
  id        String   @id @default(cuid())
  type      String
  email     String
  subject   String?
  messageId String?
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([type])
  @@index([messageId])
  @@index([createdAt])
}

// ── Email Drip Sequences ──────────────────────────────────────────────

enum DripSequenceType {
  FREE_SCAN_COMPLETED
  ACCOUNT_CREATED
  SUBSCRIPTION_ACTIVE
  TRIAL_STARTED
}

enum DripStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  UNSUBSCRIBED
}

model EmailDrip {
  id           String           @id @default(cuid())
  userId       String
  email        String
  sequence     DripSequenceType
  status       DripStatus       @default(ACTIVE)
  currentStep  Int              @default(0)
  metadata     Json?            // e.g. reportId, branche, risksFound
  startedAt    DateTime         @default(now())
  completedAt  DateTime?
  cancelledAt  DateTime?

  steps EmailDripStep[]

  @@unique([userId, sequence])
  @@index([status])
  @@index([sequence])
  @@index([email])
}

model EmailDripStep {
  id          String    @id @default(cuid())
  dripId      String
  drip        EmailDrip @relation(fields: [dripId], references: [id], onDelete: Cascade)
  step        Int
  subject     String
  scheduledAt DateTime
  sentAt      DateTime?
  messageId   String?   // Resend message ID
  status      String    @default("scheduled") // scheduled, sent, failed, skipped

  @@unique([dripId, step])
  @@index([scheduledAt])
  @@index([status])
}

// ── API Keys for Partner API ──────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String    // Friendly name, e.g. "Arbodienst X integratie"
  key         String    @unique // sk_live_... hashed
  keyPrefix   String    // First 8 chars for display: sk_live_Ab12...
  lastUsedAt  DateTime?
  requestCount Int      @default(0)
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([key])
  @@index([userId])
}

// ── Compliance Checklist Items ────────────────────────────────────────

model ComplianceCheck {
  id        String   @id @default(cuid())
  reportId  String
  report    RieReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  item      String   // e.g. "or_pvt_geinformeerd", "medewerkers_geinformeerd", "bhv_plan_actueel"
  checked   Boolean  @default(false)
  checkedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reportId, item])
  @@index([reportId])
}
