generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum PricingTier {
  GRATIS
  BASIS
  PROFESSIONAL
  ENTERPRISE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  naam      String?
  reports   RieReport[]
  branding  BrandingConfig?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model BrandingConfig {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String   @unique
  logoUrl      String?
  primaryColor String?
  companyName  String?
  websiteUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RieReport {
  id              String       @id @default(cuid())
  user            User         @relation(fields: [userId], references: [id])
  userId          String

  // Company info
  bedrijfsnaam    String
  branche         String
  aantalMedewerkers Int
  aantalLocaties  Int          @default(1)

  // Intake
  intakeData      Json

  // AI output
  generatedContent Json?
  samenvatting    String?

  // Status
  status          ReportStatus @default(PENDING)
  tier            PricingTier  @default(GRATIS)

  // PDF
  pdfGenerated    Boolean      @default(false)

  // AI metadata
  tokensUsed      Int?
  generationTimeMs Int?

  // Payment
  payments        Payment[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
}

model Payment {
  id                  String        @id @default(cuid())
  stripeSessionId     String        @unique
  stripePaymentIntent String?
  amount              Int           // cents
  currency            String        @default("eur")
  status              PaymentStatus @default(PENDING)
  tier                PricingTier
  email               String

  report              RieReport?    @relation(fields: [reportId], references: [id])
  reportId            String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([stripeSessionId])
  @@index([reportId])
}

model EmailEvent {
  id        String   @id @default(cuid())
  type      String   // email.sent, email.delivered, email.opened, email.clicked, email.bounced, email.complained
  email     String   // recipient email address
  subject   String?  // email subject (if available)
  messageId String?  // Resend message ID
  link      String?  // clicked link (for email.clicked events)
  metadata  Json?    // full event payload from Resend
  createdAt DateTime @default(now())

  @@index([email])
  @@index([type])
  @@index([messageId])
  @@index([createdAt])
}
